---
import type { HeroProps } from "@types";

type Props = HeroProps;

const { name, specialty, summary, email, location, resumeHref, profileImage } = Astro.props;

// Split name to emphasize the last word
const nameParts = name ? name.split(" ") : ["User"];
const firstName = nameParts.slice(0, -1).join(" ");
const lastName = nameParts[nameParts.length - 1];
---

<section class="relative flex h-[calc(100vh-80px)] flex-col justify-center py-2 overflow-hidden" id="hero">
  <div class="mx-auto w-full max-w-5xl px-4 text-center flex flex-col items-center z-10 relative">
    {
      profileImage && (
        <div class="relative mb-6 md:mb-8 flex h-28 w-28 md:h-36 md:w-36 lg:h-44 lg:w-44 items-center justify-center shrink-0">
          <!-- Outer Dashed Ring -->
          <div class="absolute inset-[-4px] rounded-full border-[1.5px] border-dashed border-teal-500/50 animate-[spin_12s_linear_infinite]"></div>
          <!-- Inner Node Ring -->
          <div class="absolute inset-[-12px] rounded-full border border-teal-500/20 animate-[spin_20s_linear_infinite_reverse]">
            <div class="absolute -top-1 left-1/2 h-2.5 w-2.5 -translate-x-1/2 rounded-full bg-teal-400 shadow-[0_0_10px_2px_rgba(0,240,255,0.8)]"></div>
            <div class="absolute -bottom-1 left-1/2 h-1.5 w-1.5 -translate-x-1/2 rounded-full bg-teal-400/50"></div>
          </div>
          <!-- Avatar Image Base -->
          <div class="h-full w-full overflow-hidden rounded-full border border-teal-500/30 bg-[#05070a] shadow-[0_0_40px_rgba(0,240,255,0.15)] relative z-10">
            <img src={profileImage} alt={name} class="h-full w-full object-cover transition-transform duration-700 hover:scale-105" />
          </div>
        </div>
      )
    }

    <!-- Typography -->
    <h1 class="font-sans text-4xl font-extrabold tracking-tight text-white md:text-5xl lg:text-6xl flex gap-2 justify-center flex-wrap uppercase">
      {firstName && <span class="opacity-95 drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">{firstName}</span>} 
      <span class="text-transparent" style="-webkit-text-stroke: 1.5px #00f0ff; text-shadow: 0 0 15px rgba(0,240,255,0.25); font-weight: 900;">
        {lastName}
      </span>
    </h1>
    <p class="mt-2 text-xs font-mono tracking-widest text-teal-400/90 md:text-sm uppercase bg-teal-500/10 px-3 py-1 rounded-sm border border-teal-500/20 inline-block">
      {specialty} {location && <span class="text-teal-400/50 ml-1">[{location}]</span>}
    </p>
    <p class="mx-auto mt-4 md:mt-5 max-w-2xl text-[13px] leading-relaxed text-white/70 md:text-sm font-medium">
      {summary}
    </p>

    <!-- Buttons -->
    <div class="mt-8 grid grid-cols-2 gap-3 w-full max-w-[380px] mx-auto md:flex md:w-auto md:max-w-none md:justify-center">
      <a
        href="#contact"
        class="flex w-full items-center justify-center rounded-sm bg-teal-400 px-6 py-3 text-[13px] font-bold uppercase tracking-wider text-black transition-all duration-300 hover:bg-teal-300 hover:shadow-[0_0_20px_rgba(0,240,255,0.4)] hover:-translate-y-0.5 md:w-auto"
      >
        Get in Touch
      </a>
      <a
        href="#about"
        class="flex w-full items-center justify-center rounded-sm border border-teal-500/40 bg-teal-500/5 px-6 py-3 text-[13px] font-bold uppercase tracking-wider text-teal-400 backdrop-blur-sm transition-all duration-300 hover:border-teal-400 hover:bg-teal-500/10 hover:shadow-[0_0_15px_rgba(0,240,255,0.2)] hover:-translate-y-0.5 md:w-auto"
      >
        Learn More
      </a>
    </div>

    <!-- Social Icons -->
    <div class="mt-6 md:mt-8 flex flex-wrap justify-center gap-4">
      <a
        href="https://www.linkedin.com/in/vs-vidyasagar-9b1158190/"
        target="_blank"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-teal-500/20 bg-teal-500/5 text-teal-400/70 transition-all duration-300 hover:border-teal-400 hover:text-teal-400 hover:shadow-[0_0_10px_rgba(0,240,255,0.2)]"
        aria-label="LinkedIn"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
          <rect x="2" y="9" width="4" height="12" rx="1" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
      <a
        href="https://github.com/Sagar2354"
        target="_blank"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-teal-500/20 bg-teal-500/5 text-teal-400/70 transition-all duration-300 hover:border-teal-400 hover:text-teal-400 hover:shadow-[0_0_10px_rgba(0,240,255,0.2)]"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-teal-500/20 bg-teal-500/5 text-teal-400/70 transition-all duration-300 hover:border-teal-400 hover:text-teal-400 hover:shadow-[0_0_10px_rgba(0,240,255,0.2)]"
        aria-label="Email"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Animated Metrics Strip (Wow Moment) -->
  <div class="absolute bottom-0 left-0 w-full z-20 overflow-hidden border-t border-teal-500/20 bg-[#020408]/95 backdrop-blur-md">
    <div class="flex w-full items-center justify-between px-4 py-2.5 text-[9px] md:text-xs font-mono font-medium tracking-widest text-teal-500/80 uppercase">
      <div class="flex items-center gap-2">
        <span class="relative flex h-1.5 w-1.5 md:h-2 md:w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 md:h-2 md:w-2 bg-teal-500"></span>
        </span>
        <span class="hidden xs:inline">Sys.</span>Pipeline_Active
      </div>
      <div class="hidden sm:block">Nodes: Optimal</div>
      <div>Lat: <span class="text-teal-300">12ms</span></div>
      <div>Thr: <span class="text-teal-300">99.9%</span></div>
    </div>
  </div>
</section>
