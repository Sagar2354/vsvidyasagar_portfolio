---
import type { HeroProps } from "@types";

type Props = HeroProps;

const { name, specialty, summary, email, location, resumeHref, profileImage } = Astro.props;
---

<section class="relative flex min-h-[calc(100vh-80px)] md:h-[calc(100vh-80px)] flex-col justify-center py-8 md:py-0 overflow-hidden" id="hero">
  <div class="mx-auto w-full max-w-4xl px-4 md:px-6 text-center flex flex-col items-center z-10 relative">
    
    <!-- Clean Avatar -->
    {
      profileImage && (
        <div class="mb-6 md:mb-6 h-36 w-36 md:h-32 md:w-32 shrink-0 mx-auto">
          <img src={profileImage} alt={name} class="h-full w-full object-cover rounded-full border border-white/10 grayscale-[30%] shadow-[0_0_25px_rgba(255,255,255,0.15)] transition-all duration-700 hover:shadow-[0_0_35px_rgba(255,255,255,0.3)] hover:grayscale-[10%]" />
        </div>
      )
    }

    <!-- High-Impact Name -->
    <h1 class="font-sans text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] font-medium tracking-tight text-slate-100 mx-auto max-w-3xl">
      {name}
    </h1>

    <!-- Metadata Role & Location -->
    <div class="mt-4 md:mt-4 font-mono text-[13px] tracking-[0.15em] uppercase text-slate-400 mx-auto">
      {specialty} {location && <span class="mx-2 text-slate-700">|</span>} {location}
    </div>
    
    <!-- Bio text -->
    <p class="mx-auto mt-6 md:mt-6 max-w-2xl text-[0.95rem] md:text-[0.9rem] leading-[1.7] text-slate-400 font-light px-2 md:px-0">
      {summary}
    </p>

    <!-- Refined Minimal Buttons -->
    <div class="mt-8 md:mt-8 flex flex-col md:flex-row justify-center gap-4 w-full md:w-auto mx-auto select-none">
      <a
        href="#contact"
        class="flex min-h-[48px] md:min-h-[40px] w-full md:w-auto items-center justify-center rounded-[2px] bg-slate-200 px-8 py-3 md:px-6 md:py-2 text-sm md:text-xs font-medium text-black transition-colors hover:bg-white"
      >
        Get in Touch
      </a>
      <a
        href="#about"
        class="flex min-h-[48px] md:min-h-[40px] w-full md:w-auto items-center justify-center rounded-[2px] border border-white/10 bg-transparent px-8 py-3 md:px-6 md:py-2 text-sm md:text-xs font-medium text-slate-300 transition-colors hover:bg-white/5 hover:text-white"
      >
        Learn More
      </a>
    </div>

    <!-- Bare Social Line Icons -->
    <div class="mt-10 md:mt-8 flex items-center justify-center gap-8 md:gap-6 mx-auto">
      <a
        href="https://www.linkedin.com/in/vs-vidyasagar-9b1158190/"
        target="_blank"
        class="p-2 md:p-1 text-slate-600 transition-colors hover:text-slate-300"
        aria-label="LinkedIn"
      >
        <svg viewBox="0 0 24 24" class="h-6 w-6 md:h-5 md:w-5 fill-none stroke-current stroke-[1.5]">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
          <rect x="2" y="9" width="4" height="12" rx="1" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
      <a
        href="https://github.com/Sagar2354"
        target="_blank"
        class="p-2 md:p-1 text-slate-600 transition-colors hover:text-slate-300"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" class="h-6 w-6 md:h-5 md:w-5 fill-none stroke-current stroke-[1.5]">
          <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
        </svg>
      </a>
      <a
        href="#contact"
        class="p-2 md:p-1 text-slate-600 transition-colors hover:text-slate-300"
        aria-label="Email"
      >
        <svg viewBox="0 0 24 24" class="h-6 w-6 md:h-5 md:w-5 fill-none stroke-current stroke-[1.5]">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
      </a>
    </div>
  </div>
</section>
