---
import type { HeroProps } from "@types";

type Props = HeroProps;

const { name, specialty, summary, email, location, resumeHref, profileImage } =
  Astro.props;
---

<section class="relative flex h-[calc(100vh-80px)] flex-col justify-center py-2" id="hero">
  <div class="mx-auto max-w-5xl text-center flex flex-col items-center">
    {
      profileImage && (
        <div class="mb-2 md:mb-4 h-28 w-28 md:h-36 md:w-36 lg:h-44 lg:w-44 overflow-hidden rounded-full border-4 border-primary/30 bg-[#0f172a] shadow-[0_20px_60px_rgba(2,6,23,0.35)] shrink-0">
          <img src={profileImage} alt={name} class="h-full w-full object-cover" />
        </div>
      )
    }

    <h1 class="mt-2 md:mt-4 font-serif text-2xl font-bold tracking-tight text-white md:text-3xl lg:text-4xl">
      Hi, I'm {name}
    </h1>
    <p class="mt-1 md:mt-2 text-sm font-medium text-primary md:text-base">
      {specialty}
      {location && <span class="text-white/60"> · {location}</span>}
    </p>
    <p class="mx-auto mt-2 md:mt-4 max-w-3xl text-sm leading-relaxed text-neutral md:text-sm">
      {summary}
    </p>

    <div class="mt-4 md:mt-5 flex flex-wrap items-center justify-center gap-3">
      <a
        href="#contact"
        class="rounded-full bg-primary px-6 py-2.5 text-sm font-semibold text-white transition-transform duration-300 hover:-translate-y-0.5"
      >
        Get in Touch
      </a>
      <a
        href="#about"
        class="rounded-full border border-white/14 bg-white/5 px-6 py-2.5 text-sm font-semibold text-white transition-colors duration-300 hover:border-primary hover:text-primary"
      >
        Learn More
      </a>
      {
        resumeHref && (
          <a
            href={resumeHref}
            download
            class="rounded-full border border-white/14 bg-white/5 px-6 py-2.5 text-sm font-semibold text-white transition-colors duration-300 hover:border-primary hover:text-primary"
          >
            Resume
          </a>
        )
      }
    </div>

    <div class="mt-4 md:mt-5 flex flex-wrap justify-center gap-3">
      <a
        href="https://www.linkedin.com/in/vs-vidyasagar-9b1158190/"
        target="_blank"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/12 bg-white/4 text-white/85 transition-colors duration-300 hover:border-primary hover:text-primary"
        aria-label="LinkedIn"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
          <rect x="2" y="9" width="4" height="12" rx="1" />
          <circle cx="4" cy="4" r="2" />
        </svg>
      </a>
      <a
        href="https://github.com/Sagar2354"
        target="_blank"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/12 bg-white/4 text-white/85 transition-colors duration-300 hover:border-primary hover:text-primary"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/12 bg-white/4 text-white/85 transition-colors duration-300 hover:border-primary hover:text-primary"
        aria-label="Email"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
      </a>
    </div>
  </div>
</section>
