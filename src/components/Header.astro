---
import type { HeaderProps } from "@types";

import { SITE_CONTENT } from "@config";

type Props = HeaderProps;

const { navLinks, resumeHref, brandText } = Astro.props;
const { linkedin, github } = SITE_CONTENT.hero;
---

<header class="sticky top-0 z-50 bg-[#0a1224]/60 backdrop-blur-[16px] border-b border-white/[0.08] px-4 py-4 md:px-8 shadow-sm">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 md:flex-row md:justify-between">
    <!-- Left: Brand / Logo -->
    <a href="#hero" aria-label="Home" class="flex items-center">
      <img src="/infinity.svg" class="h-8 w-auto" alt="logo" />
    </a>

    <!-- Center: Navigation Links -->
    <nav>
      <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm md:text-base lg:gap-6">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/80 hover:text-white">
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right: End Links (Social & Resume) -->
    <div class="hidden items-center gap-4 lg:flex">
      {
        linkedin && (
          <a href={linkedin} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" rx="1" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
        )
      }
      {
        github && (
          <a href={github} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
              <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
            </svg>
          </a>
        )
      }
      {
        resumeHref && (
          <a
            href={resumeHref}
            download
            class="rounded border border-primary/50 bg-primary/10 px-5 py-2 text-sm font-semibold text-primary hover:bg-primary hover:text-black"
          >
            Resume
          </a>
        )
      }
    </div>
  </div>
</header>