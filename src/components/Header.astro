---
import type { HeaderProps } from "@types";

import { SITE_CONTENT } from "@config";

type Props = HeaderProps;

const { navLinks, resumeHref } = Astro.props;
const { linkedin, github } = SITE_CONTENT.hero;
---

<header class="sticky top-0 z-50 w-full px-4 pt-4 md:px-8 flex justify-center">
  <div class="mx-auto w-full max-w-7xl flex flex-col md:flex-row md:items-center md:justify-between gap-4 px-6 md:px-8 py-3 rounded-[2rem] md:rounded-full bg-[#0a1224]/65 backdrop-blur-[20px] border border-white/[0.08] shadow-[0_20px_50px_rgba(2,6,23,0.5)] transition-all duration-300">
    
    <!-- Mobile Constrained Row: Logo, Center Resume, Hamburger -->
    <div class="flex w-full items-center justify-between md:w-auto">
      <!-- Left: Brand / Logo -->
      <a href="#hero" aria-label="Home" class="flex shrink-0 items-center pl-2">
        <img src="/infinity.svg" class="h-8 w-auto" alt="logo" />
      </a>

      <!-- Center (Mobile Only): Resume -->
      <div class="flex flex-1 items-center justify-center md:hidden">
        {
          resumeHref && (
            <a
              href={resumeHref}
              download
              class="rounded-full bg-gradient-to-r from-blue-500 to-violet-500 px-4 py-1.5 text-xs font-semibold text-white shadow-[0_0_10px_rgba(139,92,246,0.3)]"
            >
              Resume
            </a>
          )
        }
      </div>

      <!-- Right (Mobile Only): Hamburger Toggle -->
      <button id="mobile-toggle" aria-label="Toggle navigation" class="flex h-9 w-9 flex-col items-center justify-center gap-1.5 rounded-full border border-white/10 bg-white/5 md:hidden">
        <span id="line1" class="block h-0.5 w-4 origin-center bg-white/80 transition-transform duration-300"></span>
        <span id="line2" class="block h-0.5 w-4 bg-white/80 transition-opacity duration-200"></span>
        <span id="line3" class="block h-0.5 w-4 origin-center bg-white/80 transition-transform duration-300"></span>
      </button>
    </div>

    <!-- Center & Right: Navigation Links -->
    <nav class="relative hidden w-full flex-col items-center gap-6 pb-4 md:flex md:w-auto md:flex-1 md:flex-row md:gap-0 md:pb-0" id="nav-container">
      <div id="nav-indicator" class="hidden md:block absolute left-0 top-0 rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 opacity-0 pointer-events-none z-0 border border-white/10 backdrop-blur-md" style="transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), width 0.5s cubic-bezier(0.22, 1, 0.36, 1), height 0.5s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease-in-out; will-change: transform, width, height;"></div>
      
      <!-- Nav Text Node Tree -->
      <ul class="relative z-10 flex w-full flex-col items-center justify-center gap-4 md:flex-row md:gap-2 lg:gap-4 md:whitespace-nowrap">
        {
          navLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="desktop-nav-link block px-3 py-2 text-white/80 transition-colors duration-200 hover:text-white"
                data-section={link.href.substring(1)}
              >
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Right: End Links (Social & Desktop Resume) -->
      <div class="hidden shrink-0 flex-nowrap items-center gap-3 whitespace-nowrap pr-2 md:flex lg:gap-4">
        {
          linkedin && (
            <a href={linkedin} target="_blank" rel="noopener noreferrer" class="hidden text-white/80 transition-colors duration-200 hover:text-white lg:block">
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" rx="1" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
          )
        }
        {
          github && (
            <a href={github} target="_blank" rel="noopener noreferrer" class="hidden text-white/80 transition-colors duration-200 hover:text-white lg:block">
              <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
                <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
              </svg>
            </a>
          )
        }
        {
          resumeHref && (
            <a
              href={resumeHref}
              download
              class="rounded-full bg-gradient-to-r from-blue-500 to-violet-500 px-4 py-2 text-sm font-semibold text-white transition-all duration-300 hover:scale-105 hover:brightness-110 hover:shadow-[0_0_15px_rgba(139,92,246,0.5)]"
            >
              Resume
            </a>
          )
        }
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const navContainer = document.getElementById("nav-container");
    const indicator = document.getElementById("nav-indicator");
    const navLinks = document.querySelectorAll<HTMLElement>(".desktop-nav-link");
    const mobileToggle = document.getElementById("mobile-toggle");
    const line1 = document.getElementById("line1");
    const line2 = document.getElementById("line2");
    const line3 = document.getElementById("line3");

    // Hamburger Dropdown Mechanics
    if (mobileToggle && navContainer && line1 && line2 && line3) {
      mobileToggle.addEventListener("click", () => {
        const isClosed = navContainer.classList.contains("hidden");
        
        if (isClosed) {
          navContainer.classList.remove("hidden");
          navContainer.classList.add("flex");
          line1.style.transform = "rotate(45deg) translate(0px, 4px)";
          line2.style.opacity = "0";
          line3.style.transform = "rotate(-45deg) translate(0px, -4px)";
        } else {
          navContainer.classList.add("hidden");
          navContainer.classList.remove("flex");
          line1.style.transform = "none";
          line2.style.opacity = "1";
          line3.style.transform = "none";
        }
      });
      // Close mobile switch on click
      navLinks.forEach(link => {
        link.addEventListener("click", () => {
          if (window.innerWidth < 768) {
            navContainer.classList.add("hidden");
            navContainer.classList.remove("flex");
            line1!.style.transform = "none";
            line2!.style.opacity = "1";
            line3!.style.transform = "none";
          }
        });
      });
    }

    if (!navContainer || !indicator || navLinks.length === 0) return;

    let activeElement: HTMLElement | null = null;
    let isHovering = false;

    const sections = Array.from(navLinks)
      .map(link => document.getElementById(link.getAttribute("data-section") || ""))
      .filter((sec): sec is HTMLElement => sec !== null);

    function moveIndicator(element: HTMLElement | null) {
      if (!element || window.innerWidth < 768) { 
        indicator!.style.opacity = "0";
        return;
      }
      
      const containerRect = navContainer!.getBoundingClientRect();
      const linkRect = element.getBoundingClientRect();

      const left = linkRect.left - containerRect.left;
      const top = linkRect.top - containerRect.top;

      indicator!.style.transform = `translate3d(${left}px, ${top}px, 0)`;
      indicator!.style.width = `${linkRect.width}px`;
      indicator!.style.height = `${linkRect.height}px`;
      indicator!.style.opacity = "1";
    }

    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px",
      threshold: 0
    };

    const sectionObserver = new IntersectionObserver((entries: IntersectionObserverEntry[]) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          activeElement = document.querySelector<HTMLElement>(`.desktop-nav-link[data-section="${id}"]`);

          navLinks.forEach(link => {
            link.classList.remove("text-white");
            link.classList.add("text-white/80");
          });

          if (activeElement) {
            activeElement.classList.remove("text-white/80");
            activeElement.classList.add("text-white");
            
            if (!isHovering) {
              moveIndicator(activeElement);
            }
          }
        }
      });
    }, observerOptions);

    sections.forEach(sec => sectionObserver.observe(sec));

    navLinks.forEach(link => {
      link.addEventListener("mouseenter", (e) => {
        isHovering = true;
        moveIndicator(e.target as HTMLElement);
      });
    });

    navContainer.addEventListener("mouseleave", () => {
      isHovering = false;
      moveIndicator(activeElement);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
         navContainer!.classList.remove("hidden");
         navContainer!.classList.add("flex");
      } else {
         navContainer!.classList.add("hidden");
         navContainer!.classList.remove("flex");
      }
      if (!isHovering && activeElement) {
        moveIndicator(activeElement);
      }
    });

    setTimeout(() => {
      const hash = window.location.hash.substring(1);
      if (hash) {
        activeElement = document.querySelector<HTMLElement>(`.desktop-nav-link[data-section="${hash}"]`);
      } else {
        activeElement = navLinks[0] as HTMLElement;
      }
      
      if (activeElement) {
        activeElement.classList.remove("text-white/80");
        activeElement.classList.add("text-white");
        moveIndicator(activeElement);
      }
    }, 150);
  });
</script>