---
import type { HeaderProps } from "@types";

import { SITE_CONTENT } from "@config";

type Props = HeaderProps;

const { navLinks, resumeHref, brandText } = Astro.props;
const { linkedin, github } = SITE_CONTENT.hero;
---

<header class="sticky top-0 z-50 px-4 pt-5 md:px-8">
  <nav class="relative mx-auto flex max-w-5xl items-center justify-between gap-4 rounded-full border border-white/10 bg-[#0a1224]/72 px-4 py-3 shadow-[0_18px_42px_rgba(2,6,23,0.35)] backdrop-blur-2xl">
    <a href="#hero" aria-label="Home" class="shrink-0 text-base font-semibold tracking-wide text-white">
      {brandText}
    </a>

    <ul class="relative hidden flex-1 items-center justify-center gap-1 lg:flex" id="desktop-nav-list">
      <!-- Glow Indicator -->
      <div id="nav-indicator" class="absolute left-0 top-0 rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 opacity-0 transition-all duration-300 ease-out pointer-events-none z-0 border border-white/10 backdrop-blur-md"></div>
      {
        navLinks.map((link) => (
          <li class="z-10">
            <a
              href={link.href}
              class="desktop-nav-link relative block px-4 py-2 text-sm font-medium text-white/80 transition-colors duration-300 hover:text-white"
              data-section={link.href.substring(1)}
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3 md:gap-4">
      {
        linkedin && (
          <a href={linkedin} target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex text-white/80 transition-colors duration-300 hover:text-primary">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect x="2" y="9" width="4" height="12" rx="1" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
        )
      }
      {
        github && (
          <a href={github} target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex text-white/80 transition-colors duration-300 hover:text-primary">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-[1.8]">
              <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
            </svg>
          </a>
        )
      }
      {
        resumeHref && (
          <a
            href={resumeHref}
            download
            class="hidden rounded-full border border-primary/50 bg-primary/10 px-5 py-2.5 text-sm font-semibold text-primary transition-colors duration-300 hover:bg-primary hover:text-black sm:inline-block"
          >
            Resume
          </a>
        )
      }

      <button
        id="mobile-menu-btn"
        class="lg:hidden flex items-center p-1.5 ml-1 text-white/80 transition duration-300 hover:text-primary focus:outline-none"
        aria-label="Toggle Navigation"
      >
        <svg class="h-6 w-6 stroke-current" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden absolute left-4 right-4 top-20 rounded-2xl border border-white/10 bg-[#0a1224]/95 p-5 shadow-[0_18px_42px_rgba(2,6,23,0.35)] backdrop-blur-2xl lg:hidden">
    <ul class="flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block text-base font-medium text-white/80 transition-colors duration-300 hover:text-primary hover:translate-x-1"
            >
              {link.text}
            </a>
          </li>
        ))
      }
      {
        resumeHref && (
          <li class="mt-2 border-t border-white/10 pt-4 sm:hidden">
            <a
              href={resumeHref}
              download
              class="inline-block w-full text-center rounded-full border border-primary/50 bg-primary/10 px-5 py-2.5 text-sm font-semibold text-primary transition-colors duration-300 hover:bg-primary hover:text-black"
            >
              Resume
            </a>
          </li>
        )
      }
    </ul>
  </div>
</header>

<script>
  // Mobile Menu Logic
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener("click", () => {
      mobileMenu.classList.toggle("hidden");
    });
  }

  mobileNavLinks.forEach(link => {
    link.addEventListener("click", () => {
      if (mobileMenu) {
        mobileMenu.classList.add("hidden");
      }
    });
  });

  // Desktop Navbar Scrollspy & Glowing Pill Indicator
  document.addEventListener("DOMContentLoaded", () => {
    const navList = document.getElementById("desktop-nav-list");
    const indicator = document.getElementById("nav-indicator");
    const navLinks = document.querySelectorAll(".desktop-nav-link");
    
    if (!navList || !indicator || navLinks.length === 0) return;

    let activeElement = null;
    let isHovering = false;

    const sections = Array.from(navLinks)
      .map(link => document.getElementById(link.getAttribute("data-section")))
      .filter(Boolean);

    const updateIndicator = (el) => {
      if (!el) {
        indicator.style.opacity = "0";
        return;
      }
      
      const navRect = navList.getBoundingClientRect();
      const linkRect = el.getBoundingClientRect();
      
      const left = linkRect.left - navRect.left;
      const top = linkRect.top - navRect.top;
      
      indicator.style.transform = `translate(${left}px, ${top}px)`;
      indicator.style.width = `${linkRect.width}px`;
      indicator.style.height = `${linkRect.height}px`;
      indicator.style.opacity = "1";
    };

    // Intersection Observer to detect scroll position
    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px", // triggers when section is in top half
      threshold: 0
    };

    const observerCallback = (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          activeElement = document.querySelector(`.desktop-nav-link[data-section="${id}"]`);
          
          // Reset all link colors
          navLinks.forEach(l => {
            l.classList.remove('text-white');
            l.classList.add('text-white/80');
          });
          
          if (activeElement) {
            // Highlight current active
            activeElement.classList.remove('text-white/80');
            activeElement.classList.add('text-white');
            
            // Move indicator if valid
            if (!isHovering) {
              updateIndicator(activeElement);
            }
          }
        }
      });
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);
    sections.forEach(sec => observer.observe(sec));

    // Hover Interaction physics
    navLinks.forEach(link => {
      link.addEventListener("mouseenter", (e) => {
        isHovering = true;
        updateIndicator(e.target);
      });
    });

    navList.addEventListener("mouseleave", () => {
      isHovering = false;
      updateIndicator(activeElement);
    });

    // Window Resize Physics recalculation
    window.addEventListener("resize", () => {
      if (!isHovering && activeElement) {
        updateIndicator(activeElement);
      }
    });

    // Initial positioning after layout calculation
    setTimeout(() => {
      const hash = window.location.hash.substring(1);
      if (hash) {
        activeElement = document.querySelector(`.desktop-nav-link[data-section="${hash}"]`);
      } else {
        // Fallback to first section if nothing intersects yet
        activeElement = activeElement || navLinks[0];
      }
      if (activeElement) {
        activeElement.classList.remove('text-white/80');
        activeElement.classList.add('text-white');
        updateIndicator(activeElement);
      }
    }, 150);
  });
</script>
