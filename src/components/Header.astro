---
import type { HeaderProps } from "@types";

import { SITE_CONTENT } from "@config";

type Props = HeaderProps;

const { navLinks, resumeHref } = Astro.props;
const { linkedin, github } = SITE_CONTENT.hero;
---

<header class="sticky top-0 z-50 w-full bg-[#050505]/95 backdrop-blur-md border-b border-white/5 transition-all duration-300">
  <div class="mx-auto w-full max-w-7xl flex flex-col md:flex-row md:items-center md:justify-between py-4 px-6 md:px-8">
    
    <!-- Mobile Constrained Row: Logo, Center Resume, Hamburger -->
    <div class="relative flex w-full items-center justify-between md:static md:w-auto">
      <!-- Left: Brand / Logo -->
      <a href="#hero" aria-label="Home" class="flex shrink-0 items-center">
        <img src="/images/Favicon/favicon.svg" class="h-10 md:h-12 w-auto opacity-80" alt="logo" />
      </a>

      <!-- Center (Mobile Only): Resume -->
      <div class="flex items-center justify-center md:hidden">
        {
          resumeHref && (
            <a
              href={resumeHref}
              download
              class="rounded-sm border border-white/20 bg-transparent px-4 py-2 text-xs font-mono tracking-widest uppercase text-white/70 transition-colors active:bg-white/5"
            >
              Resume
            </a>
          )
        }
      </div>

      <!-- Right (Mobile Only): Hamburger Toggle -->
      <button id="mobile-toggle" aria-label="Toggle navigation" class="flex h-9 w-9 flex-col items-center justify-center gap-[4px] md:hidden">
        <span id="line1" class="block h-px w-5 origin-center bg-white/70 transition-transform duration-300"></span>
        <span id="line2" class="block h-px w-5 bg-white/70 transition-opacity duration-200"></span>
        <span id="line3" class="block h-px w-5 origin-center bg-white/70 transition-transform duration-300"></span>
      </button>
    </div>

    <!-- Center & Right: Navigation Links -->
    <nav class="relative hidden w-full flex-col items-center gap-6 pt-8 pb-4 md:flex md:w-auto md:flex-1 md:flex-row md:justify-center md:gap-8 md:p-0" id="nav-container">
      <ul class="relative z-10 flex w-full flex-col items-center justify-center gap-6 md:flex-row md:gap-8 md:whitespace-nowrap">
        {
          navLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="desktop-nav-link text-xs font-mono tracking-widest uppercase text-white/40 transition-colors duration-200 hover:text-white"
                data-section={link.href.substring(1)}
              >
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Right: End Links (Social & Desktop Resume) -->
      <div class="hidden shrink-0 flex-nowrap items-center gap-6 whitespace-nowrap pl-8 md:flex md:border-l md:border-white/10">
        {
          linkedin && (
            <a href={linkedin} target="_blank" rel="noopener noreferrer" class="hidden text-white/30 transition-colors duration-200 hover:text-white lg:block">
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.5]">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" rx="1" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
          )
        }
        {
          github && (
            <a href={github} target="_blank" rel="noopener noreferrer" class="hidden text-white/30 transition-colors duration-200 hover:text-white lg:block">
              <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.5]">
                <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
              </svg>
            </a>
          )
        }
        {
          resumeHref && (
            <a
              href={resumeHref}
              download
              class="rounded-sm border border-white/20 bg-transparent px-5 py-2.5 text-xs font-mono tracking-widest uppercase text-white/80 transition-all duration-300 hover:bg-white/5"
            >
              Resume
            </a>
          )
        }
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const navContainer = document.getElementById("nav-container");
    const navLinks = document.querySelectorAll<HTMLElement>(".desktop-nav-link");
    const mobileToggle = document.getElementById("mobile-toggle");
    const line1 = document.getElementById("line1");
    const line2 = document.getElementById("line2");
    const line3 = document.getElementById("line3");

    // Hamburger Dropdown Mechanics
    if (mobileToggle && navContainer && line1 && line2 && line3) {
      mobileToggle.addEventListener("click", () => {
        const isClosed = navContainer.classList.contains("hidden");
        
        if (isClosed) {
          navContainer.classList.remove("hidden");
          navContainer.classList.add("flex");
          line1.style.transform = "rotate(45deg) translate(0px, 4px)";
          line2.style.opacity = "0";
          line3.style.transform = "rotate(-45deg) translate(0px, -4px)";
        } else {
          navContainer.classList.add("hidden");
          navContainer.classList.remove("flex");
          line1.style.transform = "none";
          line2.style.opacity = "1";
          line3.style.transform = "none";
        }
      });

      // Close mobile menu on link click
      navLinks.forEach(link => {
        link.addEventListener("click", () => {
          if (window.innerWidth < 768) {
            navContainer.classList.add("hidden");
            navContainer.classList.remove("flex");
            line1!.style.transform = "none";
            line2!.style.opacity = "1";
            line3!.style.transform = "none";
          }
        });
      });
    }

    // Scroll active link intersection observer logic
    let activeElement: HTMLElement | null = null;
    const sections = Array.from(navLinks)
      .map(link => document.getElementById(link.getAttribute("data-section") || ""))
      .filter((sec): sec is HTMLElement => sec !== null);

    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px",
      threshold: 0
    };

    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          activeElement = document.querySelector<HTMLElement>(`.desktop-nav-link[data-section="${id}"]`);

          navLinks.forEach(link => {
            link.classList.remove("text-white");
            link.classList.add("text-white/40");
          });

          if (activeElement) {
            activeElement.classList.remove("text-white/40");
            activeElement.classList.add("text-white");
          }
        }
      });
    }, observerOptions);

    sections.forEach(sec => sectionObserver.observe(sec));

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
         navContainer!.classList.remove("hidden");
         navContainer!.classList.add("flex");
      } else {
         navContainer!.classList.add("hidden");
         navContainer!.classList.remove("flex");
      }
    });

    // Initial check
    setTimeout(() => {
      const hash = window.location.hash.substring(1);
      if (hash) {
        activeElement = document.querySelector<HTMLElement>(`.desktop-nav-link[data-section="${hash}"]`);
        if (activeElement) {
          navLinks.forEach(l => {
            l.classList.remove("text-white");
            l.classList.add("text-white/40");
          });
          activeElement.classList.remove("text-white/40");
          activeElement.classList.add("text-white");
        }
      }
    }, 150);
  });
</script>