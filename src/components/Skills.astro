---
import Section from "./Section.astro";
import type { SkillGroupProps } from "@types";

interface Props {
  skills: SkillGroupProps[];
}

const { skills } = Astro.props;
---

<Section text="Technical Skills" href="skills">
  <p class="mb-10 max-w-3xl text-lg text-neutral">
    Proficient in modern data engineering and analytics tooling for ingestion,
    transformation, orchestration, and insight delivery.
  </p>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {
      skills.map(({ title, items }) => (
        <article class="tilt-card fade-in-section rounded-3xl border border-white/10 bg-white/4 p-8 shadow-[0_24px_70px_rgba(2,6,23,0.22)]">
          <h3 class="mb-4 font-serif text-2xl font-semibold text-white">{title}</h3>
          <ul class="ml-5 list-outside list-disc space-y-3">
            {items.map((item) => (
              <li class="text-base text-neutral">{item}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</Section>
