---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Work Experience" href="experience">
  {
    experience.map(({ company, position, startDate, endDate, summary }) => (
      <article class="tilt-card fade-in-section mb-8 rounded-[28px] md:rounded-[36px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] p-8 md:p-10 shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
        <h3 class="mb-1.5 font-serif text-2xl font-semibold text-white">
          {company}
        </h3>
        <div class="flex flex-col items-start pb-5">
          <h4 class="mb-1 font-serif text-2xl font-medium text-white/90">
            {position}
          </h4>
          <span class="pb-0.5 text-sm text-white/65 tracking-widest uppercase">
            {startDate} - {endDate}
          </span>
        </div>
        {Array.isArray(summary) ? (
          <ul class="list-none">
            {summary.map((log) => (
              <li class="relative mb-3 pl-8 text-base text-white/85 glass-text before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
                {log}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-base text-white/85 glass-text">{summary}</p>
        )}
      </article>
    ))
  }
</Section>
