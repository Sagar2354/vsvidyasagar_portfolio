---
---

<div class="fixed inset-0 z-[-2] h-full w-full bg-[#030508] overflow-hidden pointer-events-none" aria-hidden="true">
  <!-- Glowing Ambient Nodes Overlay -->
  <div class="absolute top-[-10%] left-[-10%] w-[120%] h-[120%] bg-[radial-gradient(circle_at_50%_0%,rgba(0,240,255,0.06),transparent_50%),radial-gradient(circle_at_0%_100%,rgba(0,240,255,0.04),transparent_40%),radial-gradient(circle_at_100%_80%,rgba(0,240,255,0.04),transparent_40%)]"></div>

  <!-- Engineered Node Grid Pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(0,240,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,240,255,0.03)_1px,transparent_1px)] bg-[size:30px_30px] md:bg-[size:40px_40px] opacity-70"></div>

  <!-- Flowing Data Pipeline Lines -->
  <div class="absolute inset-0">
    <div class="absolute left-[20%] md:left-[15%] top-0 h-full w-[1px] bg-gradient-to-b from-transparent via-teal-400/40 to-transparent animate-pipeline-y"></div>
    <div class="absolute left-[75%] md:left-[80%] top-0 h-full w-[1px] bg-gradient-to-b from-transparent via-teal-400/30 to-transparent animate-pipeline-y-delayed"></div>
    <div class="absolute top-[30%] md:top-[25%] left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-teal-400/40 to-transparent animate-pipeline-x"></div>
    <div class="absolute top-[80%] md:top-[75%] left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-teal-400/20 to-transparent animate-pipeline-x-delayed"></div>
  </div>
</div>

<style>
  .animate-pipeline-y {
    animation: flow-y 6s ease-in-out infinite;
  }
  .animate-pipeline-y-delayed {
    animation: flow-y 8s ease-in-out infinite 2s;
  }
  .animate-pipeline-x {
    animation: flow-x 7s ease-in-out infinite 1s;
  }
  .animate-pipeline-x-delayed {
    animation: flow-x 5s ease-in-out infinite 3s;
  }

  @keyframes flow-y {
    0% { transform: translateY(-100%); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(100%); opacity: 0; }
  }
  @keyframes flow-x {
    0% { transform: translateX(-100%); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateX(100%); opacity: 0; }
  }
</style>
