---
---

<canvas
  id="particle-canvas"
  class="pointer-events-none fixed inset-0 z-[-2] h-full w-full"
  aria-hidden="true"
></canvas>

<script>
  const canvas = document.getElementById("particle-canvas") as HTMLCanvasElement;

  if (canvas) {
    const ctx = canvas.getContext("2d");

    // Handle Resize
    const setSize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    setSize();
    window.addEventListener("resize", setSize);

    // Mouse Tracking for Repel Interaction
    let mouse = { x: -1000, y: -1000 };
    window.addEventListener("mousemove", (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });

    const isMobile = window.innerWidth < 768;
    const NUM_PARTICLES = isMobile ? 20 : 40;
    const particles: Particle[] = [];

    class Particle {
      x: number;
      y: number;
      size: number;
      speedY: number;
      speedX: number;
      opacity: number;
      maxOpacity: number;
      fadeInRate: number;
      fadeOutRate: number;

      constructor() {
        this.x = 0;
        this.y = 0;
        this.size = 0;
        this.speedY = 0;
        this.speedX = 0;
        this.opacity = 0;
        this.maxOpacity = 0;
        this.fadeInRate = 0;
        this.fadeOutRate = 0;
        this.reset(true);
      }

      reset(randomY = false) {
        this.x = Math.random() * canvas.width;
        this.y = randomY ? Math.random() * canvas.height : -10;
        this.size = Math.random() * 3 + 1; // 1px to 4px
        this.speedY = Math.random() * 0.4 + 0.1; // Fall very slowly like droplets
        this.speedX = (Math.random() - 0.5) * 0.2; // Extremely subtle horizontal drift
        this.opacity = 0; // Starts invisible
        this.maxOpacity = Math.random() * 0.2 + 0.2; // Peak opacity 0.2 to 0.4
        this.fadeInRate = 0.005;
        this.fadeOutRate = 0.005;
      }

      update() {
        this.y += this.speedY;
        this.x += this.speedX;

        // Subtle Interaction: Repel from mouse pointer softly
        const dx = mouse.x - this.x;
        const dy = mouse.y - this.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const minDist = 120; // Repel radius
        if (dist < minDist) {
          const force = (minDist - dist) / minDist;
          this.x -= (dx / dist) * force * 1.5;
          this.y -= (dy / dist) * force * 1.5;
        }

        // Fade out gracefully before resetting
        if (this.y > canvas.height * 0.9) {
          this.opacity -= this.fadeOutRate;
        } else if (this.opacity < this.maxOpacity) {
          this.opacity += this.fadeInRate;
        }

        // Reset if offscreen or completely faded out at bottom
        if (this.opacity <= 0 && this.y >= canvas.height * 0.9) {
          this.reset();
        }
      }

      draw() {
        if (!ctx) return;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        // Sky Blue glow color #3ABEFF mapped to RGBA
        ctx.fillStyle = `rgba(58, 190, 255, ${Math.max(0, this.opacity)})`;
        ctx.fill();
        ctx.closePath();
      }
    }

    // Initialize particles
    for (let i = 0; i < NUM_PARTICLES; i++) {
      particles.push(new Particle());
    }

    // 60FPS Animation Loop
    const animate = () => {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      for (const p of particles) {
        p.update();
        p.draw();
      }

      requestAnimationFrame(animate);
    };

    animate();
  }
</script>
