---
import Section from "./Section.astro";
import type { AboutProps } from "@types";

type Props = AboutProps;

const { description, stats = [] } = Astro.props;
---

<Section text="About Me" href="about">
  <div class="grid gap-8 lg:grid-cols-[1.3fr_1fr]">
    <article class="tilt-card fade-in-section rounded-[28px] md:rounded-[36px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] p-8 shadow-[0_8px_32px_rgba(0,0,0,0.3)] md:p-10">
      <p class="text-lg leading-8 text-white/85 glass-text">{description}</p>
    </article>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        stats.map(({ value, label }) => (
          <article class="tilt-card fade-in-section rounded-[28px] md:rounded-[36px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] p-6 text-center shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
            <p class="mb-2 font-serif text-4xl font-bold text-white">{value}</p>
            <p class="text-sm text-white/65 tracking-widest uppercase">{label}</p>
          </article>
        ))
      }
    </div>
  </div>
</Section>
