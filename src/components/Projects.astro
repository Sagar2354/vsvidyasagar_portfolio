---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects" href="projects">
  <div class="grid gap-10">
    {
      projects.map(({ name, summary, image, techStack, linkPreview, linkSource }) => (
        <article class="tilt-card fade-in-section overflow-hidden rounded-[32px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] shadow-[0_8px_32px_rgba(0,0,0,0.3)] transition-colors duration-300 hover:bg-white/[0.15]">
          <div class="grid gap-0 xl:grid-cols-[1.2fr_1fr]">
            <div class="flex flex-col justify-between p-8 md:p-10">
              <div>
                <h3 class="mb-5 font-serif text-3xl font-medium text-white md:text-4xl">
                  {name}
                </h3>
                <p class="mb-8 max-w-2xl text-base text-white/85 glass-text md:text-lg">{summary}</p>

                {
                  techStack && techStack.length > 0 && (
                    <div class="mb-8">
                      <p class="mb-3 text-xs font-semibold tracking-[0.22em] text-white/65 uppercase">
                        Tech Stack
                      </p>
                      <div class="flex flex-wrap gap-3">
                        {techStack.map((item) => (
                          <span class="rounded-full border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 backdrop-blur-sm px-4 py-2 text-sm text-white/85 glass-text">
                            {item}
                          </span>
                        ))}
                      </div>
                    </div>
                  )
                }

              </div>

              <div class="mt-8 flex items-center justify-between gap-4">
                <div class="flex flex-wrap gap-4 text-sm text-white">
                  {
                    linkPreview && (
                      <a
                        href={linkPreview}
                        target="_blank"
                        class="after:relative after:-bottom-1 after:content-[url(/external.svg)] hover:text-primary"
                      >
                        Preview
                      </a>
                    )
                  }
                </div>

                {
                  linkSource && (
                    <a
                      href={linkSource}
                      target="_blank"
                      aria-label={`${name} GitHub repository`}
                      class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-white/20 border-t-white/30 border-l-white/30 bg-white/10 backdrop-blur-md text-white transition-colors duration-300 hover:bg-white/20"
                    >
                      <svg
                        viewBox="0 0 24 24"
                        class="h-5 w-5 fill-none stroke-current stroke-[1.8]"
                      >
                        <path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.9a3.4 3.4 0 0 0-.9-2.6c3-.3 6.1-1.5 6.1-6.7A5.2 5.2 0 0 0 18.8 4 4.8 4.8 0 0 0 18.7.4S17.5 0 15 1.7a13.4 13.4 0 0 0-6 0C6.5 0 5.3.4 5.3.4A4.8 4.8 0 0 0 5.2 4a5.2 5.2 0 0 0-1.4 3.8c0 5.2 3.1 6.4 6.1 6.7A3.4 3.4 0 0 0 9 17.1V21" />
                      </svg>
                    </a>
                  )
                }
              </div>
            </div>

            {
              image && (
                <div class="relative min-h-[320px] overflow-hidden border-t border-white/8 xl:min-h-full xl:border-t-0 xl:border-l">
                  <div class="absolute inset-0 bg-linear-to-br from-primary/12 via-transparent to-sky-400/10"></div>
                  <img
                    src={image}
                    alt={name}
                    class="h-full w-full object-cover object-top"
                  />
                </div>
              )
            }
          </div>
        </article>
      ))
    }
  </div>
</Section>
