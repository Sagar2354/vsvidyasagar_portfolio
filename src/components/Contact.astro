---
import Section from "./Section.astro";
import type { ContactProps } from "@types";

type Props = ContactProps;

const { email, phone, location, linkedin, github, resumeHref } = Astro.props;
---

<Section text="Contact" href="contact">
  <div class="rounded-[28px] md:rounded-[36px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] p-8 md:p-10 shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
    <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-white/65 uppercase">
      Let's Build Something Useful
    </p>
    <p class="mb-8 max-w-2xl text-base text-white/85 glass-text">
      I am open to data engineering roles, cloud data platform work, and projects
      focused on scalable pipelines, data quality, and analytics enablement.
    </p>

    <div class="grid gap-4 md:grid-cols-2">
      <a class="rounded-2xl border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 backdrop-blur-sm p-5 hover:bg-white/10 transition-colors" href={`mailto:${email}`}>
        <p class="mb-2 text-xs text-white/65 tracking-widest uppercase">Email</p>
        <p class="text-base text-white">{email}</p>
      </a>
      <div class="rounded-2xl border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 backdrop-blur-sm p-5">
        <p class="mb-2 text-xs text-white/65 tracking-widest uppercase">Phone</p>
        <p class="text-base text-white">{phone}</p>
      </div>
      <div class="rounded-2xl border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 backdrop-blur-sm p-5">
        <p class="mb-2 text-xs text-white/65 tracking-widest uppercase">Location</p>
        <p class="text-base text-white">{location}</p>
      </div>
      <div class="flex flex-wrap gap-3 rounded-2xl border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 backdrop-blur-sm p-5">
        {linkedin && (
          <a
            href={linkedin}
            target="_blank"
            class="inline-flex items-center justify-center rounded-lg border border-white/20 border-t-white/30 border-l-white/30 bg-white/10 backdrop-blur-md px-4 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-white/20"
          >
            LinkedIn
          </a>
        )}
        {github && (
          <a
            href={github}
            target="_blank"
            class="inline-flex items-center justify-center rounded-lg border border-white/20 border-t-white/30 border-l-white/30 bg-white/10 backdrop-blur-md px-4 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-white/20"
          >
            GitHub
          </a>
        )}
        {resumeHref && (
          <a
            href={resumeHref}
            target="_blank"
            class="inline-flex items-center justify-center rounded-lg border border-white/20 border-t-white/30 border-l-white/30 bg-white/10 backdrop-blur-md px-4 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-white/20"
          >
            Resume
          </a>
        )}
      </div>
    </div>
  </div>
</Section>
