---
import Section from "./Section.astro";
import type { CertificationProps } from "@types";

interface Props {
  certifications: CertificationProps[];
  achievements: string[];
}

const { certifications, achievements } = Astro.props;
---

<Section text="Certificates" href="highlights">
  <div class="grid gap-6 lg:grid-cols-2">
    <article class="tilt-card fade-in-section rounded-3xl border border-white/10 bg-white/4 p-8 md:p-10 shadow-[0_24px_70px_rgba(2,6,23,0.22)]">
      <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-primary uppercase">
        Certifications
      </p>
      <ul class="space-y-4">
        {certifications.map(({ title, href }) => (
          <li class="relative pl-8 text-base text-neutral before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
            <a href={href} target="_blank" class="hover:text-primary hover:underline">
              {title}
            </a>
          </li>
        ))}
      </ul>
    </article>

    <article class="tilt-card fade-in-section rounded-3xl border border-white/10 bg-white/4 p-8 md:p-10 shadow-[0_24px_70px_rgba(2,6,23,0.22)]">
      <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-primary uppercase">
        Achievements
      </p>
      <ul class="space-y-4">
        {achievements.map((item) => (
          <li class="relative pl-8 text-base text-neutral before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
            {item}
          </li>
        ))}
      </ul>
    </article>
  </div>
</Section>
