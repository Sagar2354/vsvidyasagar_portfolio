---
import Section from "./Section.astro";
import type { CertificationProps } from "@types";

interface Props {
  certifications: CertificationProps[];
  achievements: string[];
}

const { certifications, achievements } = Astro.props;
---

<Section text="Certificates" href="highlights">
  <div class="grid gap-6 lg:grid-cols-2">
    <article class="tilt-card fade-in-section rounded-[28px] md:rounded-[36px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] p-8 md:p-10 shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
      <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-white/65 uppercase">
        Certifications
      </p>
      <ul class="space-y-4">
        {certifications.map(({ title, href }) => (
          <li class="relative pl-8 text-base text-white/85 glass-text before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
            <a href={href} target="_blank" class="hover:text-white hover:underline transition-colors">
              {title}
            </a>
          </li>
        ))}
      </ul>
    </article>

    <article class="tilt-card fade-in-section rounded-[28px] md:rounded-[36px] border border-white/10 border-t-white/20 border-l-white/20 bg-white/5 md:bg-white/10 backdrop-blur-[12px] md:backdrop-blur-[20px] p-8 md:p-10 shadow-[0_8px_32px_rgba(0,0,0,0.3)]">
      <p class="mb-4 text-xs font-semibold tracking-[0.22em] text-white/65 uppercase">
        Achievements
      </p>
      <ul class="space-y-4">
        {achievements.map((item) => (
          <li class="relative pl-8 text-base text-white/85 glass-text before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
            {item}
          </li>
        ))}
      </ul>
    </article>
  </div>
</Section>
